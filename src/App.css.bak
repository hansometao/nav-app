:root{--bg-primary:#0a0a18;--bg-secondary:#12122a;--bg-card:#1a1c38;--bg-card-hover:#1e2045;--bg-card-elevated:#222450;--text-primary:#eaeaf2;--text-secondary:#9898b8;--text-muted:#6a6a88;--accent:#6c63ff;--accent-light:#8b83ff;--accent-soft:rgba(108,99,255,0.12);--accent-glow:rgba(108,99,255,0.35);--accent-glow-strong:rgba(108,99,255,0.5);--success:#4ade80;--warning:#fbbf24;--danger:#f87171;--border:#262652;--border-light:#31316a;--radius:12px;--radius-sm:8px;--radius-xs:6px;--shadow-sm:0 1px 3px rgba(0,0,0,0.3);--shadow-md:0 4px 12px rgba(0,0,0,0.4);--shadow-lg:0 8px 30px rgba(0,0,0,0.5);--transition-fast:0.15s cubic-bezier(0.4,0,0.2,1);--transition-base:0.25s cubic-bezier(0.4,0,0.2,1);--transition-slow:0.35s cubic-bezier(0.4,0,0.2,1)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg-primary);color:var(--text-primary);min-height:100vh;line-height:1.6}
#root{min-height:100vh}
.app{min-height:100vh;display:flex;flex-direction:column}
.app-header{display:flex;justify-content:space-between;align-items:center;padding:14px 20px;background:var(--bg-secondary);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:1000;backdrop-filter:blur(12px);transition:all 0.3s}
.app-header.edit-mode{border-bottom-color:var(--accent);box-shadow:0 2px 20px var(--accent-glow)}
.header-left{display:flex;align-items:baseline;gap:12px}
.app-title{font-size:20px;font-weight:700;background:linear-gradient(135deg,var(--accent),var(--accent-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.app-subtitle{font-size:11px;color:var(--text-secondary)}
.header-right{display:flex;align-items:center;gap:14px}
.header-time{text-align:right}
.time-display{font-size:24px;font-weight:700;font-variant-numeric:tabular-nums;color:var(--text-primary);display:block;line-height:1.2}
.date-display{font-size:11px;color:var(--text-secondary)}
.header-greeting{font-size:13px;color:var(--accent-light);padding:4px 12px;background:rgba(108,99,255,0.1);border-radius:20px;white-space:nowrap}
.header-controls{display:flex;gap:8px;align-items:center}
.btn-edit-mode{background:rgba(108,99,255,0.1);border:1px solid var(--border);color:var(--text-secondary);padding:5px 12px;border-radius:6px;font-size:12px;cursor:pointer;transition:all 0.2s;font-weight:500}
.btn-edit-mode:hover{background:rgba(108,99,255,0.2);border-color:var(--accent)}
.btn-edit-mode.active{background:var(--accent);border-color:var(--accent);color:white}
.btn-reset-layout{background:rgba(248,113,113,0.1);border:1px solid var(--danger);color:var(--danger);padding:5px 12px;border-radius:6px;font-size:12px;cursor:pointer;transition:all 0.2s}
.btn-reset-layout:hover{background:var(--danger);color:white}
.app-main{flex:1;padding:16px;max-width:1600px;margin:0 auto;width:100%}
.top-search-section{background:var(--bg-secondary);border-bottom:1px solid var(--border);padding:20px 0}
.search-container{max-width:900px;margin:0 auto;padding:0 20px}
.search-section-compact{margin-bottom:0}
.search-bar-large{padding:4px 4px 4px 6px}
.search-bar-large .search-input{font-size:16px;padding:12px 14px}
.search-bar-large .btn-search{padding:10px 24px;font-size:14px}
.search-bar-large .search-engine-btn{padding:10px 14px}
.draggable-grid{min-height:200px}
.widget-container{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;display:flex;flex-direction:column;height:100%;box-shadow:var(--shadow-sm);transition:box-shadow var(--transition-base),border-color var(--transition-base),transform var(--transition-base)}
.widget-container:hover{border-color:var(--accent);box-shadow:var(--shadow-md),0 0 24px var(--accent-glow);transform:translateY(-1px)}
.widget-container.dragging{opacity:0.9;border-color:var(--accent);box-shadow:var(--shadow-lg),0 0 36px var(--accent-glow-strong);z-index:100;transform:rotate(0.5deg)}
.widget-content{flex:1;padding:14px;overflow:auto;min-height:0}
.widget-drag-handle{font-size:16px;color:var(--text-secondary);cursor:grab;user-select:none;padding:2px 6px;border-radius:4px;transition:all 0.15s;line-height:1}
.widget-drag-handle:hover{color:var(--accent-light);background:rgba(108,99,255,0.1)}
.widget-drag-handle:active{cursor:grabbing}
.widget-title-label{font-size:12px;color:var(--text-secondary);font-weight:500;letter-spacing:0.5px}
.widget-header-spacer{flex:1}
.widget-resize-hint{font-size:14px;color:var(--accent);opacity:0.6;cursor:pointer;padding:2px 4px;border-radius:4px;transition:all 0.15s}
.widget-resize-hint:hover{opacity:1;background:rgba(108,99,255,0.1)}
.react-grid-item.react-grid-placeholder{background:var(--accent)!important;opacity:0.3;border-radius:var(--radius)}
.react-grid-item>.react-resizable-handle{opacity:0;transition:opacity 0.2s;z-index:10}
.react-grid-item:hover>.react-resizable-handle,
.react-grid-item.resizing>.react-resizable-handle{opacity:1}
.react-grid-item>.react-resizable-handle::after{
  background: var(--accent);
  width: 10px;
  height: 10px;
  border-radius: 2px;
}
.react-grid-item > .react-resizable-handle.react-resizable-handle-se,
.react-grid-item > .react-resizable-handle.react-resizable-handle-sw,
.react-grid-item > .react-resizable-handle.react-resizable-handle-ne,
.react-grid-item > .react-resizable-handle.react-resizable-handle-nw {
  width: 20px;
  height: 20px;
}
.widget{background:transparent;border:none;padding:0;transition:none}
.widget-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.widget-header h3{font-size:14px;font-weight:600}
.search-section{margin-bottom:0}
.search-bar{display:flex;align-items:center;background:var(--bg-card);border:1px solid var(--border);border-radius:50px;padding:3px 3px 3px 4px;transition:all 0.2s}
.search-bar:focus-within{border-color:var(--accent);box-shadow:0 0 20px var(--accent-glow)}
.search-engine-select{flex-shrink:0;position:relative}
.search-engine-btn{display:flex;align-items:center;gap:4px;background:rgba(108,99,255,0.1);border:none;color:var(--text-primary);padding:8px 12px;border-radius:50px;cursor:pointer;font-size:13px;transition:all 0.2s;white-space:nowrap}
.search-engine-btn:hover{background:rgba(108,99,255,0.2)}
.search-engine-dropdown{position:absolute;top:100%;left:0;margin-top:4px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);box-shadow:0 4px 20px rgba(0,0,0,0.3);z-index:1000;min-width:140px;overflow:hidden}
.se-dropdown-item{display:flex;align-items:center;gap:6px;width:100%;background:none;border:none;color:var(--text-primary);padding:8px 12px;font-size:13px;cursor:pointer;transition:all 0.15s;text-align:left}
.se-dropdown-item:hover{background:rgba(108,99,255,0.1)}
.se-dropdown-item.active{background:rgba(108,99,255,0.2);color:var(--accent-light);font-weight:600}
.se-name{font-weight:600;font-size:12px}
.se-arrow{font-size:10px;color:var(--text-secondary);margin-left:2px}
.search-input{flex:1;background:none;border:none;outline:none;color:var(--text-primary);font-size:15px;padding:10px 12px;min-width:0}
.search-input::placeholder{color:var(--text-secondary);opacity:0.7}
.search-input:focus::placeholder{opacity:1}
.btn-search{background:var(--accent);color:white;border:none;border-radius:50px;padding:8px 20px;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;flex-shrink:0}
.btn-search:hover{background:var(--accent-light)}
.search-engines-bar{display:flex;gap:4px;margin-top:8px;justify-content:center}
.se-tab{background:rgba(255,255,255,0.03);border:1px solid transparent;color:var(--text-secondary);padding:4px 12px;border-radius:50px;cursor:pointer;font-size:12px;transition:all 0.2s}
.se-tab:hover{color:var(--text-primary);background:rgba(255,255,255,0.06)}
.se-tab.active{background:rgba(108,99,255,0.15);border-color:var(--accent);color:var(--accent-light);font-weight:600}
.quick-links-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.quick-link-item{display:flex;flex-direction:column;align-items:center;gap:3px;padding:10px 6px;border-radius:var(--radius-sm);text-decoration:none;color:var(--text-primary);transition:all 0.2s;background:rgba(255,255,255,0.03)}
.quick-link-item:hover{background:rgba(108,99,255,0.1);transform:translateY(-2px)}
.ql-icon{font-size:22px}
.ql-name{font-size:11px;color:var(--text-secondary);text-align:center}
.ai-tools-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:6px}
.ai-tool-card{display:flex;align-items:center;gap:8px;padding:10px;border-radius:var(--radius-sm);text-decoration:none;color:var(--text-primary);transition:all 0.2s;background:rgba(255,255,255,0.03)}
.ai-tool-card:hover{background:rgba(108,99,255,0.1);transform:translateY(-2px)}
.ai-tool-icon{font-size:24px;flex-shrink:0}
.ai-tool-name{font-size:13px;font-weight:600}
.ai-tool-desc{font-size:10px;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.add-bookmark-form{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;padding:12px;background:rgba(255,255,255,0.02);border-radius:var(--radius-sm);border:1px solid var(--border)}
.add-bookmark-form input{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 10px;color:var(--text-primary);font-size:13px;outline:none}
.add-bookmark-form input:focus{border-color:var(--accent)}
.bookmark-form-row{display:flex;flex-direction:column;gap:8px}
.icon-picker{display:flex;flex-wrap:wrap;gap:3px;align-items:center;font-size:12px;color:var(--text-secondary)}
.icon-option{background:rgba(255,255,255,0.05);border:1px solid transparent;border-radius:4px;padding:3px 5px;font-size:14px;cursor:pointer;transition:all 0.15s}
.icon-option:hover,.icon-option.active{background:rgba(108,99,255,0.2);border-color:var(--accent)}
.cat-input{max-width:120px}
.bookmark-form-actions{display:flex;gap:8px}
.empty-state{text-align:center;padding:20px;color:var(--text-secondary);font-size:13px}
.bookmark-categories-scrollable{display:flex;flex-direction:column;gap:14px;max-height:340px;overflow-y:auto;padding-right:4px}
.bookmark-category{background:rgba(255,255,255,0.02);border-radius:var(--radius-sm);padding:10px;border:1px solid var(--border)}
.category-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.category-title{font-size:12px;color:var(--accent-light);text-transform:uppercase;letter-spacing:1px;display:flex;align-items:center;gap:6px}
.cat-icon{font-size:14px}
.cat-count{font-size:10px;color:var(--text-secondary);font-weight:400;text-transform:none;letter-spacing:0}
.category-actions{display:flex;gap:4px}
.cat-action-btn{background:transparent;border:1px solid var(--border);border-radius:4px;width:20px;height:20px;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
.cat-action-btn:hover{background:var(--accent);border-color:var(--accent);color:white}
.cat-action-btn.cat-delete:hover{background:var(--danger);border-color:var(--danger)}
.category-edit-input{background:rgba(255,255,255,0.1);border:1px solid var(--accent);border-radius:4px;padding:2px 6px;color:var(--text-primary);font-size:11px;outline:none;width:80px}
.category-edit-input-inline{background:rgba(255,255,255,0.1);border:1px solid var(--accent);border-radius:4px;padding:2px 6px;color:var(--text-primary);font-size:11px;outline:none}
.bookmark-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.bookmark-item{position:relative;background:rgba(255,255,255,0.03);border-radius:var(--radius-sm);padding:10px 8px;transition:all 0.2s;border:1px solid transparent}
.bookmark-item:hover{background:rgba(108,99,255,0.08);border-color:var(--accent);transform:translateY(-2px)}
.bookmark-link{display:flex;flex-direction:column;align-items:center;gap:6px;text-decoration:none;color:var(--text-primary)}
.bm-icon{font-size:24px;margin-bottom:2px}
.bm-name{font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;text-align:center;font-weight:500}
.bookmark-actions{display:none;position:absolute;top:6px;right:6px;gap:2px;background:var(--bg-secondary);padding:2px;border-radius:4px;border:1px solid var(--border)}
.bookmark-item:hover .bookmark-actions{display:flex}
.bm-action-btn{background:transparent;border:1px solid var(--border);border-radius:4px;width:20px;height:20px;font-size:9px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
.bm-action-btn:hover{background:var(--accent);border-color:var(--accent);color:white}
.city-selector{position:relative}
.btn-city{background:rgba(108,99,255,0.1);border:1px solid var(--border);color:var(--accent-light);padding:4px 12px;border-radius:50px;font-size:12px;cursor:pointer;transition:all 0.2s}
.btn-city:hover{background:rgba(108,99,255,0.2)}
.city-picker-dropdown{background:var(--bg-secondary);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px;margin-bottom:12px;max-height:220px;overflow:hidden;display:flex;flex-direction:column}
.city-search-input{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:6px 10px;color:var(--text-primary);font-size:12px;outline:none;margin-bottom:6px}
.city-search-input:focus{border-color:var(--accent)}
.city-list{overflow-y:auto;display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.city-option{background:none;border:1px solid transparent;color:var(--text-secondary);padding:5px 8px;border-radius:4px;font-size:12px;cursor:pointer;transition:all 0.15s;text-align:center}
.city-option:hover{background:rgba(108,99,255,0.1);color:var(--text-primary)}
.city-option.active{background:rgba(108,99,255,0.15);border-color:var(--accent);color:var(--accent-light);font-weight:600}
.weather-current{text-align:center;padding:10px 0;border-bottom:1px solid var(--border);margin-bottom:10px}
.weather-temp-row{display:flex;align-items:center;justify-content:center;gap:10px}
.weather-icon-big{font-size:40px}
.weather-temp{font-size:38px;font-weight:700}
.weather-desc{font-size:13px;color:var(--text-secondary);margin-top:2px}
.weather-details{display:flex;justify-content:center;gap:14px;margin-top:6px;font-size:11px;color:var(--text-secondary)}
.weather-info{font-size:12px;color:var(--text-secondary);text-align:center;padding:4px 0}
.weather-update{font-size:10px;opacity:0.6;margin-top:2px}
.weather-data-source{text-align:center;font-size:10px;color:var(--text-secondary);opacity:0.5;margin-top:8px}
.weather-loading,.weather-error{text-align:center;padding:20px;color:var(--text-secondary);font-size:13px}
.calendar-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.calendar-title{font-size:13px;font-weight:600}
.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;margin-bottom:10px}
.calendar-day-header{text-align:center;font-size:10px;color:var(--text-secondary);padding:3px 0;font-weight:600}
.calendar-day{text-align:center;padding:5px 2px;border-radius:3px;font-size:12px;cursor:default;min-height:28px}
.calendar-day.empty{visibility:hidden}
.calendar-day.today{background:var(--accent);color:white;font-weight:700}
.calendar-day.has-event{font-weight:600}
.day-num{display:block}
.day-events{display:flex;justify-content:center;gap:1px;font-size:5px;color:var(--accent);line-height:1}
.event-list{border-top:1px solid var(--border);padding-top:10px}
.event-list h4{font-size:11px;color:var(--text-secondary);margin-bottom:6px}
.event-item{display:flex;align-items:center;gap:6px;padding:2px 0;font-size:11px}
.event-date{color:var(--accent-light);font-size:10px;min-width:75px}
.event-title{flex:1}
.add-event-form{display:flex;flex-direction:column;gap:6px;margin-bottom:10px;padding:10px;background:rgba(255,255,255,0.02);border-radius:var(--radius-sm);border:1px solid var(--border)}
.add-event-form input{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 10px;color:var(--text-primary);font-size:12px;outline:none}
.add-event-form input:focus{border-color:var(--accent)}
.color-picker-row{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary)}
.color-picker-row input[type="color"]{width:28px;height:28px;border:none;border-radius:4px;cursor:pointer;padding:0;background:none}
.todo-count{font-size:12px;color:var(--accent-light);font-weight:600}
.todo-form{display:flex;gap:6px;margin-bottom:10px}
.todo-input{flex:1;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 10px;color:var(--text-primary);font-size:13px;outline:none}
.todo-input:focus{border-color:var(--accent)}
.todo-filters{display:flex;gap:4px;margin-bottom:10px}
.todo-filter-btn{background:none;border:1px solid var(--border);color:var(--text-secondary);padding:3px 10px;border-radius:50px;font-size:11px;cursor:pointer;transition:all 0.15s}
.todo-filter-btn:hover{color:var(--text-primary)}
.todo-filter-btn.active{background:rgba(108,99,255,0.15);border-color:var(--accent);color:var(--accent-light);font-weight:600}
.todo-list{display:flex;flex-direction:column;gap:4px;max-height:240px;overflow-y:auto}
.todo-item{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:var(--radius-sm);background:rgba(255,255,255,0.02);transition:all 0.15s}
.todo-item:hover{background:rgba(255,255,255,0.04)}
.todo-item.done .todo-text{text-decoration:line-through;opacity:0.5}
.todo-check-label{position:relative;width:18px;height:18px;cursor:pointer;flex-shrink:0}
.todo-checkbox{position:absolute;opacity:0;cursor:pointer}
.todo-checkmark{position:absolute;top:0;left:0;width:18px;height:18px;border:2px solid var(--border);border-radius:4px;transition:all 0.2s;display:flex;align-items:center;justify-content:center}
.todo-checkbox:checked+.todo-checkmark{background:var(--success);border-color:var(--success)}
.todo-checkbox:checked+.todo-checkmark::after{content:'✓';color:#000;font-size:11px;font-weight:700}
.todo-text{flex:1;font-size:13px;cursor:pointer;user-select:none}
.todo-footer{display:flex;justify-content:flex-end;margin-top:8px}
.btn-text{background:none;border:none;color:var(--text-secondary);font-size:11px;cursor:pointer;transition:color 0.2s}
.btn-text:hover{color:var(--danger)}
.countdown-list{display:flex;flex-direction:column;gap:10px;margin-bottom:14px}
.countdown-item{border-left:3px solid var(--accent);padding:8px 10px;background:rgba(255,255,255,0.02);border-radius:0 var(--radius-sm) var(--radius-sm) 0}
.countdown-label{font-size:12px;font-weight:600;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center}
.countdown-time{display:flex;align-items:center;justify-content:center;gap:3px}
.cd-num{font-size:20px;font-weight:700;font-variant-numeric:tabular-nums}
.cd-num small{font-size:10px;font-weight:400;color:var(--text-secondary);margin-left:1px}
.cd-sep{font-size:18px;color:var(--text-secondary);margin:0 2px}
.cd-sec{color:var(--accent-light)}
.countdown-expired{text-align:center;font-size:14px;padding:6px}
.timer-section{border-top:1px solid var(--border);padding-top:10px}
.timer-section h4{font-size:11px;color:var(--text-secondary);margin-bottom:6px}
.timer-controls{display:flex;gap:6px;align-items:center}
.timer-input{flex:1;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:6px 10px;color:var(--text-primary);font-size:13px;outline:none;max-width:80px}
.timer-input:focus{border-color:var(--accent)}
.timer-display{text-align:center;font-size:32px;font-weight:700;font-variant-numeric:tabular-nums;color:var(--accent-light);padding:10px 0;animation:pulse 1s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.7}}
.memo-count{font-size:12px;color:var(--text-secondary)}
.memo-form{display:flex;flex-direction:column;gap:8px;margin-bottom:14px;padding:12px;background:rgba(255,255,255,0.02);border-radius:var(--radius-sm);border:1px solid var(--border)}
.memo-title-input{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:7px 10px;color:var(--text-primary);font-size:13px;outline:none}
.memo-title-input:focus{border-color:var(--accent)}
.memo-content-input{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:var(--radius-sm);padding:8px 10px;color:var(--text-primary);font-size:13px;outline:none;resize:vertical;font-family:inherit;line-height:1.5}
.memo-content-input:focus{border-color:var(--accent)}
.memo-color-picker{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text-secondary)}
.color-dot{width:22px;height:22px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:all 0.15s}
.color-dot:hover{transform:scale(1.2)}
.color-dot.active{border-color:white;box-shadow:0 0 8px rgba(255,255,255,0.3);transform:scale(1.15)}
.memo-form-actions{display:flex;gap:8px}
.memo-grid{display:grid;grid-template-columns:1fr;gap:8px}@media(min-width:768px){.memo-grid{grid-template-columns:repeat(2,1fr)}}
.memo-card{background:rgba(255,255,255,0.02);border-radius:var(--radius-sm);border:1px solid var(--border);border-top:3px solid;padding:10px;transition:all 0.2s}
.memo-card:hover{background:rgba(255,255,255,0.04)}
.memo-card-header{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.memo-card-color{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.memo-card-title{font-size:13px;font-weight:600;flex:1}
.memo-card-time{font-size:10px;color:var(--text-secondary)}
.memo-card-content{font-size:12px;color:var(--text-secondary);line-height:1.5;white-space:pre-wrap;word-break:break-word}
.memo-card-actions{display:none;margin-top:8px;justify-content:flex-end;gap:4px}
.memo-card:hover .memo-card-actions{display:flex}
.btn-icon{background:none;border:1px solid var(--border);color:var(--text-secondary);width:26px;height:26px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:all 0.2s;flex-shrink:0}
.btn-icon:hover{background:var(--accent);color:white;border-color:var(--accent)}
.btn-remove{font-size:14px;width:20px;height:20px}
.btn-remove:hover{background:var(--danger);border-color:var(--danger)}
.btn-sm{background:var(--accent);color:white;border:none;border-radius:var(--radius-sm);padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;white-space:nowrap}
.btn-sm:hover{background:var(--accent-light)}
.btn-cancel{background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--text-secondary)}
.btn-cancel:hover{background:rgba(255,255,255,0.1);color:var(--text-primary)}
.btn-success{background:var(--success);color:#000}
.btn-success:hover{background:#6ee7a0}
.btn-danger{background:var(--danger)}
.btn-danger:hover{background:#fca5a5}
.app-footer{text-align:center;padding:16px;color:var(--text-secondary);font-size:12px;border-top:1px solid var(--border);background:var(--bg-secondary)}
.hotnews-widget .widget-header h3{font-size:13px}.hotnews-update{font-size:10px;color:var(--text-secondary)}.hotnews-platforms{display:flex;gap:6px;margin-bottom:8px}.hotnews-platform{background:rgba(255,255,255,0.03);border:1px solid var(--border);color:var(--text-primary);padding:6px 12px;border-radius:20px;font-size:12px;cursor:pointer;transition:all 0.2s;white-space:nowrap;display:flex;align-items:center;gap:4px}.hotnews-platform:hover{background:rgba(255,255,255,0.06)}.hotnews-platform.active{background:var(--platform-color);border-color:var(--platform-color);color:#fff;font-weight:600}.hotnews-tabs{display:flex;gap:4px;margin-bottom:10px;flex-wrap:wrap}.hotnews-tab{background:rgba(255,255,255,0.03);border:1px solid var(--border);color:var(--text-secondary);padding:4px 10px;border-radius:20px;font-size:11px;cursor:pointer;transition:all 0.2s;white-space:nowrap}.hotnews-tab:hover{color:var(--text-primary);background:rgba(255,255,255,0.06)}.hotnews-tab.active{background:rgba(108,99,255,0.15);border-color:var(--accent);color:var(--accent-light);font-weight:600}.hotnews-list{display:flex;flex-direction:column;gap:6px;max-height:260px;overflow-y:auto}.hotnews-item{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;text-decoration:none;color:var(--text-primary);transition:all 0.2s;background:rgba(255,255,255,0.02)}.hotnews-item:hover{background:rgba(108,99,255,0.1);transform:translateX(2px)}.hotnews-rank{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;background:rgba(255,255,255,0.08);color:var(--text-secondary);flex-shrink:0}.hotnews-rank.rank-1{background:linear-gradient(135deg,#ffd700,#ffb700);color:#000}.hotnews-rank.rank-2{background:linear-gradient(135deg,#c0c0c0,#a0a0a0);color:#000}.hotnews-rank.rank-3{background:linear-gradient(135deg,#cd7f32,#a0522d);color:#fff}.hotnews-title{flex:1;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.hotnews-heat{font-size:10px;color:var(--text-secondary);white-space:nowrap}.hotnews-loading,.hotnews-error{text-align:center;padding:20px;color:var(--text-secondary);font-size:13px}.hotnews-error{color:var(--danger)}.hotnews-source{text-align:center;font-size:10px;color:var(--text-secondary);opacity:0.5;margin-top:6px;padding-top:6px;border-top:1px dashed var(--border)}
@media(max-width:1100px){.app-main{padding:14px}.app-header{flex-direction:column;gap:8px;padding:12px}.header-right{width:100%;justify-content:space-between}.bookmark-grid{grid-template-columns:repeat(3,1fr)}.top-search-section{padding:16px 0}}
@media(max-width:996px){.bookmark-grid{grid-template-columns:repeat(4,1fr)}.ai-tools-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.search-container{padding:0 16px}.search-bar-large{padding:3px 3px 3px 4px}.search-bar-large .search-input{font-size:14px;padding:10px 12px}.search-bar-large .btn-search{padding:8px 16px;font-size:13px}.bookmark-grid{grid-template-columns:repeat(3,1fr)}.quick-links-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:600px){.quick-links-grid{grid-template-columns:repeat(3,1fr)}.ai-tools-grid{grid-template-columns:1fr}.bookmark-grid{grid-template-columns:repeat(2,1fr)}.city-list{grid-template-columns:repeat(3,1fr)}.time-display{font-size:20px}.search-bar{flex-wrap:wrap}.search-engine-btn{padding:6px 10px}.top-search-section{padding:12px 0}.search-container{padding:0 12px}.bookmark-item{padding:8px 6px}.bm-icon{font-size:20px}.bm-name{font-size:10px}}